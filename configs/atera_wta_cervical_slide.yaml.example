case_name: atera_wta_cervical_slide
data:
  mode: xenium_slide
  slide_store: outputs/xenium_slides/atera/cervical/xenium_slide.zarr
  patch_manifest: outputs/xenium_slides/atera/cervical/contour_patches_manifest.json
  output_dir: outputs/xenium_slides/atera/stgpt/cervical
  slide_id: atera_wta_cervical_preview
  organ: cervix
  batch_id: atera_wta_preview
  stain: H&E
  cluster_key: cluster
  structure_key: structure_id
  region_id_key: contour_id
  min_cells_per_region: 1
  gene_name_key: feature_name
  spatial_key: spatial
  include_structure_context: true
  image_size: 224
model:
  d_model: 256
  n_heads: 8
  n_layers: 4
  max_genes: 1200
  n_expression_bins: 51
  image_size: 224
  patch_scales: [1, 2]
  max_cells_per_region: 64
  use_cell_context: true
  dropout: 0.1
training:
  batch_size: 32
  learning_rate: 0.0001
  lr_schedule: cosine
  warmup_steps: 500
  max_steps: 10000
  save_every_n_steps: 1000
  image_gene_loss_warmup_steps: 1000
  neighborhood_loss_warmup_steps: 1000
  structure_loss_warmup_steps: 1000
  mask_probability: 0.15
  neighborhood_k: 8
  output_dir: outputs/xenium_slides/atera/stgpt/cervical/train
  device: cuda
  num_workers: 4
split:
  strategy: spatial_block
  train_fraction: 0.70
  val_fraction: 0.15
  test_fraction: 0.15
